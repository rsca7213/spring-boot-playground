<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1osfr43" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.36.1" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.7.0">
  <bpmn:process id="process-payment" name="Process Payment" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Payment Request Received">
      <bpmn:outgoing>Flow_11y6uvf</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:scriptTask id="Activity_1mrcxr9" name="Prepare Transaction">
      <bpmn:extensionElements>
        <zeebe:script expression="=total * 1.1" resultVariable="totalWithTax" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_11y6uvf</bpmn:incoming>
      <bpmn:outgoing>Flow_0czoo3a</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:serviceTask id="Activity_163l3h2" name="Charge Credit Card">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="charge-credit-card" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0czoo3a</bpmn:incoming>
      <bpmn:outgoing>Flow_1g3v5jq</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_015csmu" name="Payment Executed">
      <bpmn:incoming>Flow_1g3v5jq</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_11y6uvf" sourceRef="StartEvent_1" targetRef="Activity_1mrcxr9" />
    <bpmn:sequenceFlow id="Flow_0czoo3a" sourceRef="Activity_1mrcxr9" targetRef="Activity_163l3h2" />
    <bpmn:sequenceFlow id="Flow_1g3v5jq" sourceRef="Activity_163l3h2" targetRef="Event_015csmu" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
