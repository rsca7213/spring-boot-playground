import com.playground.api.entities.Policy
import com.playground.api.exceptions.ApiException
import com.playground.api.enums.ErrorCode
import org.springframework.http.HttpStatus;

rule "Verify that the policy is not deleted"
when
    deleted : Policy(deleted == true)
then
    throw new ApiException("Policy has been deleted", ErrorCode.ITEM_DOES_NOT_EXIST, HttpStatus.NOT_FOUND);
end